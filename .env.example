# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/trading_bot

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Encryption (generate once, NEVER lose) ────
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_MASTER_KEY=

# ── JWT ───────────────────────────────────────
JWT_SECRET=

# ── Exchange (OKX) ────────────────────────────
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# ── Telegram Bot ──────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Google OAuth ──────────────────────────────
GOOGLE_CLIENT_ID=

# ── Dashboard URL ─────────────────────────────
DASHBOARD_URL=https://dnatradingbot.com

