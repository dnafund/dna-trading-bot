# ── Exchange (OKX) ────────────────────────────
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# ── Telegram Bot ──────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Trading ───────────────────────────────────
# "paper" or "live"
TRADING_MODE=paper
# Comma-separated symbol override (optional, bot auto-scans if empty)
# TRADING_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# ── Web Dashboard ─────────────────────────────
JWT_SECRET=
DASHBOARD_URL=http://localhost:8000
# Initial deposit amount for growth % calculation
# INITIAL_DEPOSIT=300.0
# Performance analysis reset date (ISO format, optional)
# ANALYSIS_RESET_DATE=2026-01-01T00:00:00

# ── Google OAuth (optional) ───────────────────
# Backend + Frontend both need this for Google login
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Frontend uses VITE_GOOGLE_CLIENT_ID (set in web/frontend/.env)
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── Database (optional, defaults to SQLite) ───
# DATABASE_URL=postgresql://user:password@localhost:5432/trading_bot

# ── Redis (optional) ─────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ── Encryption (optional) ────────────────────
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_MASTER_KEY=

# ── Stripe (optional) ────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Sentry (optional) ────────────────────────
# SENTRY_DSN=
